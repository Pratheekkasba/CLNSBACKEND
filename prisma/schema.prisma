generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  role                   UserRole                @default(PROSPECT)
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  password               String
  status                 UserStatus              @default(PENDING)
  email                  String                  @unique
  name                   String?
  barId                  String?
  bio                    String?
  college                String?
  resumeUrl              String?
  imageUrl               String?
  advocateCases          Case[]                  @relation("AdvocateCases")
  cases                  Case[]                  @relation("ClientCases")
  internshipApplications InternshipApplication[]
  postedInternships      InternshipPosting[]
  mentorshipsAsMentor    Mentorship[]            @relation("Mentor")
  mentorshipsAsStudent   Mentorship[]            @relation("Student")
  createdPrograms        MentorshipProgram[]
  verificationRequests   VerificationRequest[]

  @@map("users")
}

model SystemLog {
  id          String   @id @default(uuid())
  action      String
  description String
  userId      String?
  createdAt   DateTime @default(now())
}

model VerificationRequest {
  id          String   @id @default(uuid())
  userId      String
  status      String   @default("PENDING")
  documentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id])
}

model Case {
  id          String     @id @default(uuid())
  title       String
  status      CaseStatus @default(OPEN)
  clientId    String
  advocateId  String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  description String?
  type        String     @default("General")
  advocate    User?      @relation("AdvocateCases", fields: [advocateId], references: [id])
  client      User       @relation("ClientCases", fields: [clientId], references: [id])
  hearings    Hearing[]
}

model Hearing {
  id        String   @id @default(uuid())
  date      DateTime
  title     String
  court     String?
  caseId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
}

model Mentorship {
  id                 String              @id @default(uuid())
  status             String              @default("ACTIVE")
  mentorId           String
  studentId          String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  programId          String?
  mentor             User                @relation("Mentor", fields: [mentorId], references: [id])
  program            MentorshipProgram?  @relation(fields: [programId], references: [id])
  student            User                @relation("Student", fields: [studentId], references: [id])
  mentorshipSessions MentorshipSession[]
}

model MentorshipSession {
  id           String     @id @default(uuid())
  mentorshipId String
  date         DateTime
  duration     Int
  notes        String?
  status       String     @default("SCHEDULED")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  mentorship   Mentorship @relation(fields: [mentorshipId], references: [id])
}

model MentorshipProgram {
  id          String       @id @default(uuid())
  title       String
  focusArea   String
  description String
  duration    String
  capacity    Int
  status      String       @default("OPEN")
  authorId    String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mentorships Mentorship[]
  author      User         @relation(fields: [authorId], references: [id])
}

model InternshipPosting {
  id           String                  @id @default(uuid())
  title        String
  company      String
  location     String
  description  String
  type         String
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  authorId     String?
  deadline     DateTime?
  duration     String?
  stipend      String?
  status       String                  @default("OPEN")
  applications InternshipApplication[]
  author       User?                   @relation(fields: [authorId], references: [id])
}

model InternshipApplication {
  id        String            @id @default(uuid())
  status    String            @default("PENDING")
  studentId String
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt
  postingId String
  coverNote String?
  posting   InternshipPosting @relation(fields: [postingId], references: [id])
  student   User              @relation(fields: [studentId], references: [id])
}

enum UserRole {
  PROSPECT
  CLIENT
  ADVOCATE
  ADMIN
  STUDENT
}

enum UserStatus {
  PENDING
  ACTIVE
  VERIFIED
  REJECTED
  SUSPENDED
}

enum CaseStatus {
  OPEN
  CLOSED
  PENDING
}
